<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SST Web App: Proverifica & Modelo Italiano</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .tab-content { display: none; }
        .tab-content.active { display: block; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <header class="bg-blue-900 text-white p-6 shadow-md">
        <h1 class="text-2xl font-bold text-center">Gestión Integral de Salud en el Trabajo</h1>
        <p class="text-center text-sm opacity-80">Implementación Proverifica + Modelo Obrero Italiano</p>
    </header>

    <main class="max-w-5xl mx-auto mt-8 p-4">
        <div class="flex border-b border-gray-200 mb-6">
            <button onclick="showTab('italiano')" class="py-2 px-4 font-semibold text-blue-600 border-b-2 border-blue-600 focus:outline-none">Modelo Obrero Italiano</button>
            <button onclick="showTab('proverifica')" class="py-2 px-4 font-semibold text-gray-500 hover:text-blue-600 focus:outline-none">Modelo Proverifica</button>
        </div>

        <section id="italiano" class="tab-content active">
            <div class="bg-white p-6 rounded-lg shadow">
                <h2 class="text-xl font-bold mb-4 text-blue-800">Validación por el Grupo Homogéneo</h2>
                <p class="mb-4 text-sm">Registro de percepción de riesgos por parte de los trabajadores (No delegación).</p>
                
                <form id="form-italiano" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium">Área de Trabajo:</label>
                        <input type="text" class="w-full border rounded p-2" placeholder="Ej. Línea de Ensamble">
                    </div>
                    <div>
                        <label class="block text-sm font-medium">Factor de Riesgo Identificado:</label>
                        <select class="w-full border rounded p-2">
                            <option>Ambiente Físico (Ruido, Temperatura)</option>
                            <option>Carga de Trabajo (Ergonomía)</option>
                            <option>Factores Psicosociales</option>
                        </select>
                    </div>
                    <button type="button" class="bg-green-600 text-white px-6 py-2 rounded hover:bg-green-700">Registrar Hallazgo</button>
                </form>
            </div>
        </section>

        <section id="proverifica" class="tab-content">
            <div class="bg-white p-6 rounded-lg shadow">
                <h2 class="text-xl font-bold mb-4 text-blue-800">Listas de Verificación (Checklists)</h2>
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-100">
                            <th class="p-3 border">Criterio de Verificación</th>
                            <th class="p-3 border">Cumple</th>
                            <th class="p-3 border">Observaciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="p-3 border text-sm">¿Se cuenta con el acta de integración de la comisión?</td>
                            <td class="p-3 border"><input type="checkbox"></td>
                            <td class="p-3 border"><input type="text" class="w-full text-xs border p-1"></td>
                        </tr>
                        <tr>
                            <td class="p-3 border text-sm">¿Existen registros de capacitación del último trimestre?</td>
                            <td class="p-3 border"><input type="checkbox"></td>
                            <td class="p-3 border"><input type="text" class="w-full text-xs border p-1"></td>
                        </tr>
                    </tbody>
                </table>
                <button class="mt-4 bg-blue-700 text-white px-6 py-2 rounded hover:bg-blue-800">Generar Reporte Proverifica</button>
            </div>
        </section>
    </main>

    <script>
        function showTab(id) {
            // Ocultar todos
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
            // Quitar estilos activos de botones
            document.querySelectorAll('button').forEach(btn => btn.classList.replace('text-blue-600', 'text-gray-500'));
            document.querySelectorAll('button').forEach(btn => btn.classList.remove('border-b-2', 'border-blue-600'));
            
            // Mostrar seleccionado
            document.getElementById(id).classList.add('active');
            event.currentTarget.classList.replace('text-gray-500', 'text-blue-600');
            event.currentTarget.classList.add('border-b-2', 'border-blue-600');
        }
    </script>
</body>
</html>
